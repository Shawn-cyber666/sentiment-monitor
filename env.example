# ============================================
# 服务器配置
# ============================================
NODE_ENV=development
PORT=5000

# ============================================
# MongoDB 配置
# ============================================
MONGODB_URI=mongodb://localhost:27017/sentiment-monitor
MONGODB_USER=admin
MONGODB_PASSWORD=your_password

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# 小红书 API 配置
# ============================================
XIAOHONGSHU_API_KEY=your_xiaohongshu_api_key
XIAOHONGSHU_API_SECRET=your_xiaohongshu_api_secret

# ============================================
# 微博 API 配置
# ============================================
WEIBO_APP_KEY=your_weibo_app_key
WEIBO_APP_SECRET=your_weibo_app_secret
WEIBO_ACCESS_TOKEN=your_weibo_access_token

# ============================================
# B站 API 配置
# ============================================
BILIBILI_SESSDATA=your_bilibili_sessdata
BILIBILI_BILI_JCT=your_bili_jct

# ============================================
# 爬虫配置
# ============================================
CRAWLER_INTERVAL_HOURS=4
CRAWLER_BATCH_SIZE=50
CRAWLER_TIMEOUT=30

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============================================
# 安全配置
# ============================================
JWT_SECRET=your_jwt_secret_key
API_KEY=your_api_key
ENCRYPTION_KEY=your_encryption_key_32_chars_long

# ============================================
# 邮件配置 (用于告警)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL=admin@example.com

# ============================================
# 第三方服务配置
# ============================================
DATA_PROVIDER_API_KEY=your_data_provider_key
DATA_PROVIDER_URL=https://api.dataprovider.com

# ============================================
# 开发配置
# ============================================
DEBUG=false
CORS_ORIGIN=http://localhost:3000
