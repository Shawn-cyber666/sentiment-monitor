{
  "name": "sentiment-monitor-backend",
  "version": "1.0.0",
  "description": "Vivo X300U Sentiment Monitoring Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.js\"",
    "docker:build": "docker build -t sentiment-backend:latest .",
    "docker:run": "docker run -p 5000:5000 sentiment-backend:latest"
  },
  "keywords": [
    "sentiment",
    "monitoring",
    "vivo",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "cors": "^2.8.5",
    "mongoose": "^8.0.0",
    "redis": "^4.6.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "eslint": "^8.53.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
